{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start User Service",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}\\backend\\user-service"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Course Service",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}\\backend\\course-service"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start API Gateway",
      "type": "shell",
      "command": "mvn spring-boot:run",
      "options": {
        "cwd": "${workspaceFolder}\\backend\\api-gateway"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}\\microservices-app\\frontend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start All Services",
      "dependsOn": [
        "Start User Service",
        "Start Course Service",
        "Start API Gateway",
        "Start Frontend"
      ],
      "problemMatcher": []
    },
    {
      "label": "Docker Compose Up",
      "type": "shell",
      "command": "docker-compose up --build",
      "options": {
        "cwd": "${workspaceFolder}\\microservices-app"
      },
      "problemMatcher": []
    }
  ]
}
